#!/bin/sh
# Auto-format staged Dart files before every commit, so the CI format
# check (dart format --set-exit-if-changed) can never fail on formatting.
#
# One-time setup after cloning:   git config core.hooksPath .githooks

files=$(git diff --cached --name-only --diff-filter=ACMR -- '*.dart')
[ -z "$files" ] && exit 0

if ! command -v dart >/dev/null 2>&1; then
  echo "pre-commit: 'dart' not on PATH — skipping format check." >&2
  exit 0
fi

echo "$files" | while IFS= read -r f; do
  [ -f "$f" ] && dart format "$f" >/dev/null
done

# Re-stage anything the formatter touched.
echo "$files" | while IFS= read -r f; do
  [ -f "$f" ] && git add "$f"
done

exit 0
